---
import "../styles/global.css";
import { config } from "../data/config";

interface Props {
  title?: string;
}

const { title = config.businessName } = Astro.props;
---

<!doctype html>
<html lang={config.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <main class="mx-auto max-w-md px-4 py-6 sm:max-w-3xl sm:px-6 lg:max-w-6xl">
      <slot />
    </main>

    <script src="../scripts/filters.ts"></script>
  </body>
</html>