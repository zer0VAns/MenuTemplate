---
import MenuLayout from "../layouts/MenuLayout.astro";
import Header from "../components/layout/Header.astro";
import CategoryNav from "../components/layout/CategoryNav.astro";
import ScrollToTop from "../components/layout/ScrollToTop.astro";
import FeaturedSection from "../components/menu/FeaturedSection.astro";
import CategorySection from "../components/menu/CategorySection.astro";
import ProductDetail from "../components/menu/ProductDetail.astro";
import { menu } from "../data/menu";

const allProducts = menu.categories.flatMap((category) => category.products);
---

<MenuLayout>
  <Header />

  <div class="sticky top-0 z-30 -mx-4 sm:-mx-6">
    <CategoryNav categories={menu.categories} />
  </div>

  <FeaturedSection menu={menu} />

  {menu.categories.map((category) => (
    <CategorySection category={category} />
  ))}

  <p data-search-empty-state hidden class="py-12 text-center text-sm text-[var(--color-text-muted)]">
    No encontramos productos que coincidan con tu búsqueda.
  </p>

  <ProductDetail products={allProducts} />
  <ScrollToTop />
</MenuLayout>