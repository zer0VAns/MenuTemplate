---
import type { Product } from "../../types/menu";
import { config } from "../../data/config";

interface Props {
  products: Product[];
}

const { products } = Astro.props;
const productsJson = JSON.stringify(products).replace(/</g, "\\u003c");
---

<dialog
  data-product-dialog
  data-currency={config.currency}
  data-language={config.language}
  class="fixed inset-0 z-50 hidden h-full w-full max-h-full max-w-full m-0 border-none bg-transparent p-0 open:flex items-end justify-center sm:items-center"
>
  <div class="relative max-h-[85vh] w-full overflow-y-auto rounded-t-2xl bg-[var(--color-surface)] p-5 sm:max-w-lg sm:rounded-2xl sm:p-6">
    <button
      type="button"
      data-dialog-close
      aria-label="Cerrar"
      class="absolute right-4 top-4 flex h-8 w-8 cursor-pointer items-center justify-center rounded-full bg-[var(--color-surface-muted)] text-[var(--color-text-muted)]"
    >
      ✕
    </button>

    <div data-dialog-image-wrapper class="mb-4 h-48 w-full overflow-hidden rounded-xl bg-[var(--color-surface-muted)]">
      <img data-dialog-image alt="" class="h-full w-full object-cover" />
    </div>

    <div class="flex items-start justify-between gap-3">
      <h3 data-dialog-name class="font-display text-xl font-bold text-[var(--color-text)]"></h3>
      <span data-dialog-price class="shrink-0 font-display text-xl font-bold text-[var(--color-primary)]"></span>
    </div>

    <span
      data-dialog-unavailable
      hidden
      class="mt-2 inline-block rounded-full bg-[var(--color-unavailable-badge)] px-2.5 py-1 text-xs font-medium uppercase tracking-wide text-white"
    >
      No disponible
    </span>

    <p data-dialog-description class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]"></p>

    <div data-dialog-diet-tags class="mt-3 flex flex-wrap gap-1.5"></div>

    <div data-dialog-ingredients-wrapper hidden class="mt-4">
      <h4 class="mb-1 text-sm font-semibold text-[var(--color-text)]">Ingredientes</h4>
      <p data-dialog-ingredients class="text-sm text-[var(--color-text-muted)]"></p>
    </div>

    <div data-dialog-allergens-wrapper hidden class="mt-4">
      <h4 class="mb-1 text-sm font-semibold text-[var(--color-text)]">Alérgenos</h4>
      <p data-dialog-allergens class="text-sm text-[var(--color-text-muted)]"></p>
    </div>

    <div data-dialog-related-wrapper hidden class="mt-5">
      <h4 class="mb-2 text-sm font-semibold text-[var(--color-text)]">También te puede gustar</h4>
      <div data-dialog-related class="flex gap-2 overflow-x-auto no-scrollbar"></div>
    </div>
  </div>
</dialog>

<script type="application/json" id="menu-products-data" set:html={productsJson} />

<script>
  interface ProductData {
    id: string;
    name: string;
    price: number;
    image?: string;
    description?: string;
    ingredients?: string[];
    allergens?: string[];
    dietTags?: string[];
    featuredTags?: string[];
    available?: boolean;
    calories?: number;
    relatedProductIds?: string[];
  }

  const dialog = document.querySelector<HTMLDialogElement>("[data-product-dialog]");
  const dataScript = document.querySelector<HTMLScriptElement>("#menu-products-data");

  if (dialog && dataScript) {
    const products: ProductData[] = JSON.parse(dataScript.textContent ?? "[]");
    const productsById = new Map(products.map((p) => [p.id, p]));

    const priceFormatter = new Intl.NumberFormat(dialog.dataset.language, {
      style: "currency",
      currency: dialog.dataset.currency,
      maximumFractionDigits: 0,
    });

    const dietLabels: Record<string, string> = {
      vegan: "Vegano",
      vegetarian: "Vegetariano",
      spicy: "Picante",
      "gluten-free": "Sin gluten",
      "lactose-free": "Sin lactosa",
    };

    const els = {
      imageWrapper: dialog.querySelector<HTMLElement>("[data-dialog-image-wrapper]"),
      image: dialog.querySelector<HTMLImageElement>("[data-dialog-image]"),
      name: dialog.querySelector<HTMLElement>("[data-dialog-name]"),
      price: dialog.querySelector<HTMLElement>("[data-dialog-price]"),
      unavailable: dialog.querySelector<HTMLElement>("[data-dialog-unavailable]"),
      description: dialog.querySelector<HTMLElement>("[data-dialog-description]"),
      dietTags: dialog.querySelector<HTMLElement>("[data-dialog-diet-tags]"),
      ingredientsWrapper: dialog.querySelector<HTMLElement>("[data-dialog-ingredients-wrapper]"),
      ingredients: dialog.querySelector<HTMLElement>("[data-dialog-ingredients]"),
      allergensWrapper: dialog.querySelector<HTMLElement>("[data-dialog-allergens-wrapper]"),
      allergens: dialog.querySelector<HTMLElement>("[data-dialog-allergens]"),
      relatedWrapper: dialog.querySelector<HTMLElement>("[data-dialog-related-wrapper]"),
      related: dialog.querySelector<HTMLElement>("[data-dialog-related]"),
    };

    function renderProduct(product: ProductData) {
      const isAvailable = product.available !== false;

      if (els.imageWrapper && els.image) {
        if (product.image) {
          els.image.src = product.image;
          els.image.alt = product.name;
          els.imageWrapper.hidden = false;
        } else {
          els.imageWrapper.hidden = true;
        }
      }

      if (els.name) els.name.textContent = product.name;
      if (els.price) els.price.textContent = priceFormatter.format(product.price);
      if (els.unavailable) els.unavailable.hidden = isAvailable;

      if (els.description) {
        els.description.textContent = product.description ?? "";
        els.description.hidden = !product.description;
      }

      if (els.dietTags) {
        els.dietTags.innerHTML = "";
        (product.dietTags ?? []).forEach((tag) => {
          const span = document.createElement("span");
          span.className =
            "inline-flex items-center rounded-full bg-[var(--color-surface-muted)] px-2.5 py-1 text-xs text-[var(--color-text-muted)]";
          span.textContent = dietLabels[tag] ?? tag;
          els.dietTags?.appendChild(span);
        });
      }

      if (els.ingredientsWrapper && els.ingredients) {
        const has = (product.ingredients?.length ?? 0) > 0;
        els.ingredientsWrapper.hidden = !has;
        if (has) els.ingredients.textContent = product.ingredients!.join(", ");
      }

      if (els.allergensWrapper && els.allergens) {
        const has = (product.allergens?.length ?? 0) > 0;
        els.allergensWrapper.hidden = !has;
        if (has) els.allergens.textContent = product.allergens!.join(", ");
      }

      if (els.relatedWrapper && els.related) {
        const relatedIds = product.relatedProductIds ?? [];
        const relatedProducts = relatedIds
          .map((id) => productsById.get(id))
          .filter((p): p is ProductData => Boolean(p));

        els.relatedWrapper.hidden = relatedProducts.length === 0;
        els.related.innerHTML = "";

        relatedProducts.forEach((rp) => {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className =
            "flex shrink-0 cursor-pointer flex-col items-start gap-0.5 rounded-xl border border-[var(--color-border)] px-3 py-2 text-left transition-colors hover:border-[var(--color-primary)]";
          btn.innerHTML = `<span class="text-sm font-medium text-[var(--color-text)]">${rp.name}</span><span class="text-xs text-[var(--color-text-muted)]">${priceFormatter.format(rp.price)}</span>`;
          btn.addEventListener("click", () => renderProduct(rp));
          els.related?.appendChild(btn);
        });
      }

      dialog?.querySelector(".overflow-y-auto")?.scrollTo(0, 0);
    }

    document.addEventListener("click", (event) => {
      const card = (event.target as HTMLElement)?.closest<HTMLElement>("[data-product-card]");
      if (!card) return;

      const productId = card.dataset.productId;
      const product = productId ? productsById.get(productId) : undefined;
      if (!product) return;

      renderProduct(product);
      dialog.showModal();
    });

    dialog.querySelector("[data-dialog-close]")?.addEventListener("click", () => dialog.close());

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });
  }
</script>