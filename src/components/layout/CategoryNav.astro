---
import Icon from "../ui/Icon.astro";

interface CategoryNavItem {
  id: string;
  name: string;
  icon?: string;
}

interface Props {
  categories: CategoryNavItem[];
}

const { categories } = Astro.props;
---

<nav
  data-category-nav
  class="flex items-center gap-2 border-b border-[var(--color-border)] bg-[var(--color-surface)]/95 px-4 py-3 backdrop-blur sm:px-6"
>
  <div class="flex flex-1 gap-2 overflow-x-auto no-scrollbar">
    <button
      type="button"
      data-category-button
      data-category-value="all"
      data-active="true"
      class="flex shrink-0 cursor-pointer items-center gap-1.5 rounded-full border border-[var(--color-border)] px-3 py-1.5 text-sm font-medium text-[var(--color-text-muted)] transition-colors data-[active=true]:border-[var(--color-primary)] data-[active=true]:bg-[var(--color-primary)] data-[active=true]:text-[var(--color-primary-foreground)]"
    >
      Todos
    </button>

    {categories.map((category) => (
      <button
        type="button"
        data-category-button
        data-category-value={category.id}
        data-active="false"
        class="flex shrink-0 cursor-pointer items-center gap-1.5 rounded-full border border-[var(--color-border)] px-3 py-1.5 text-sm font-medium text-[var(--color-text-muted)] transition-colors data-[active=true]:border-[var(--color-primary)] data-[active=true]:bg-[var(--color-primary)] data-[active=true]:text-[var(--color-primary-foreground)]"
      >
        {category.icon && <Icon name={category.icon} class="h-4 w-4" />}
        {category.name}
      </button>
    ))}
  </div>

  <div class="relative hidden shrink-0 sm:block">
    <span class="pointer-events-none absolute left-2.5 top-1/2 -translate-y-1/2 text-sm text-[var(--color-text-muted)]" aria-hidden="true">
      🔍
    </span>
    <input
      type="search"
      data-search-input
      placeholder="Buscar..."
      class="w-28 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-muted)] py-1.5 pl-8 pr-3 text-sm text-[var(--color-text)] outline-none transition-all focus:w-40 focus:border-[var(--color-primary)] sm:w-36 sm:focus:w-52"
    />
  </div>
</nav>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-category-button]");
  const input = document.querySelector<HTMLInputElement>("[data-search-input]");

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const categoryId = button.dataset.categoryValue ?? "all";

      buttons.forEach((b) => {
        b.dataset.active = String(b.dataset.categoryValue === categoryId);
      });

      window.dispatchEvent(
        new CustomEvent("category-change", { detail: { categoryId } })
      );
    });
  });

  input?.addEventListener("input", () => {
    window.dispatchEvent(
      new CustomEvent("search-change", { detail: { query: input.value } })
    );
  });
</script>