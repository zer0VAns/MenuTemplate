---
import { config } from "../../data/config";

interface Props {
  overBanner?: boolean;
}

const { overBanner = false } = Astro.props;
const { businessName, hours, theme } = config;

const navItems = ["Inicio", "Menú", "Nosotros"];
const activeItem = "Menú";
---

<header
  data-page-header
  class:list={[
    "flex items-center justify-between gap-2 py-3",
    overBanner && "rounded-2xl bg-black/25 px-3 shadow-lg backdrop-blur-md",
  ]}
>
  <div class="flex min-w-0 items-center gap-2.5">
    {theme.logoUrl && (
      <img
        src={theme.logoUrl}
        alt={businessName}
        class="h-9 w-9 shrink-0 rounded-full object-cover ring-2 ring-white/50 sm:h-10 sm:w-10"
      />
    )}
    <h1
      class:list={[
        "truncate font-display text-lg font-extrabold tracking-tight sm:text-2xl",
        overBanner ? "text-white" : "text-[var(--color-text)]",
      ]}
    >
      {businessName}
    </h1>
  </div>

  <nav class="hidden shrink-0 gap-1 sm:flex">
    {navItems.map((item) => (
      <button
        type="button"
        class:list={[
          "cursor-pointer rounded-full px-3 py-1.5 text-sm font-medium transition-colors",
          item === activeItem
            ? "bg-[var(--color-primary)] text-[var(--color-primary-foreground)]"
            : overBanner
              ? "text-white/90 hover:bg-white/15 hover:text-white"
              : "text-[var(--color-text-muted)] hover:bg-[var(--color-surface-muted)] hover:text-[var(--color-text)]",
        ]}
      >
        {item}
      </button>
    ))}
  </nav>

  <div class="flex shrink-0 items-center gap-1.5 sm:gap-2">
    <div
      class:list={[
        "hidden items-center gap-1.5 text-sm sm:flex",
        overBanner ? "text-white/90" : "text-[var(--color-text-muted)]",
      ]}
    >
      <span
        class:list={[
          "h-2 w-2 shrink-0 rounded-full",
          hours.isOpenNow ? "bg-green-500" : "bg-gray-400",
        ]}
        aria-hidden="true"
      />
      {hours.statusLabel ?? (hours.isOpenNow ? "Abierto" : "Cerrado")}
    </div>

    <span
      class:list={[
        "flex h-2 w-2 shrink-0 rounded-full sm:hidden",
        hours.isOpenNow ? "bg-green-500" : "bg-gray-400",
      ]}
      aria-label={hours.isOpenNow ? "Abierto" : "Cerrado"}
    />

    <div class="relative sm:hidden">
      <button
        type="button"
        data-menu-toggle
        aria-label="Abrir menú"
        aria-expanded="false"
        class:list={[
          "flex h-9 w-9 shrink-0 cursor-pointer flex-col items-center justify-center gap-1 rounded-full",
          overBanner ? "hover:bg-white/15" : "hover:bg-[var(--color-surface-muted)]",
        ]}
      >
        <span class:list={["h-0.5 w-5", overBanner ? "bg-white" : "bg-[var(--color-text)]"]}></span>
        <span class:list={["h-0.5 w-5", overBanner ? "bg-white" : "bg-[var(--color-text)]"]}></span>
        <span class:list={["h-0.5 w-5", overBanner ? "bg-white" : "bg-[var(--color-text)]"]}></span>
      </button>

      <nav
        data-mobile-menu
        hidden
        class="absolute right-0 top-full z-40 mt-2 flex w-40 flex-col gap-1 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-2 shadow-lg"
      >
        {navItems.map((item) => (
          <button
            type="button"
            class:list={[
              "cursor-pointer rounded-lg px-3 py-2 text-left text-sm font-medium transition-colors",
              item === activeItem
                ? "bg-[var(--color-primary)] text-[var(--color-primary-foreground)]"
                : "text-[var(--color-text-muted)] hover:bg-[var(--color-surface-muted)] hover:text-[var(--color-text)]",
            ]}
          >
            {item}
          </button>
        ))}
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = !menu.hidden;
      menu.hidden = isOpen;
      toggle.setAttribute("aria-expanded", String(!isOpen));
    });

    document.addEventListener("click", (event) => {
      const target = event.target as Node;
      if (!menu.hidden && !menu.contains(target) && !toggle.contains(target)) {
        menu.hidden = true;
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  }
</script>